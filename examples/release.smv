MODULE main
VAR
    light: {on, off};  -- Light can be either on or off
    switch: boolean;   -- Switch can be either TRUE (on) or FALSE (off)
    
INIT
    light = off & switch = FALSE

TRANS
    (light = on & next(light) = on & switch = TRUE) | (light = off & next(light) = off & switch = FALSE)

LTLSPEC G (switch V (light = on))

